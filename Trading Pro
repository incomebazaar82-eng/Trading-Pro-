    :[['User',r.userName||'—'],['Email',r.user||'—'],['Method',r.method||'—'],['Amount',adFmtAmt(r.amount)],['Account Name',r.accountName||'—'],['Account No',r.accountNumber||'—'],['Wallet',r.wallet||'—'],['Coin',r.coin||'—'],['Network',r.network||'—'],['Time',adFmtTime(r.timestamp)],['Status',r.status.toUpperCase()]];
  document.getElementById('adMBody').innerHTML=fields.filter(([,v])=>v&&v!=='—')
    .map(([l,v])=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(0,180,255,0.07);font-size:12px;"><span style="color:var(--txt2);font-size:10px;text-transform:uppercase;">${l}</span><span style="font-weight:600;text-align:right;word-break:break-all;max-width:200px;">${v}</span></div>`).join('');
  document.getElementById('adMActs').innerHTML=r.status==='pending'
    ?`<button onclick="adApprove('${r.id}')" style="flex:1;padding:12px;border-radius:12px;border:none;background:linear-gradient(135deg,#006030,#00e676);color:#001808;font-family:'Orbitron',monospace;font-size:11px;font-weight:700;cursor:pointer;">✅ APPROVE</button>
       <button onclick="adReject('${r.id}')" style="flex:1;padding:12px;border-radius:12px;border:none;background:linear-gradient(135deg,#6a0000,#ff1744);color:#fff;font-family:'Orbitron',monospace;font-size:11px;font-weight:700;cursor:pointer;">❌ REJECT</button>`
    :`<div style="text-align:center;width:100%;color:var(--txt2);font-size:12px;">Resolved: <b style="color:${r.status==='approved'?'var(--green)':'var(--red)'}">${r.status.toUpperCase()}</b></div>`;
  document.getElementById('adModal').style.display='flex';
}
function adCloseModal(){document.getElementById('adModal').style.display='none';}

