function pickA(btn,n,p){document.querySelectorAll('.achip').forEach(b=>b.classList.remove('on'));btn.classList.add('on');asset=n;price=p;initCandles();drawChart();updSent();}
function setTF(btn){document.querySelectorAll('.tf').forEach(b=>b.classList.remove('on'));btn.classList.add('on');initCandles();drawChart();}
function setTA(v){document.getElementById('TA').value=v;updP();}
function chgA(d){const e=document.getElementById('TA');const c=parseFloat(e.value)||1;const s=c>=100?10:c>=10?5:1;e.value=Math.max(1,c+d*s);updP();}
function updP(){const a=parseFloat(document.getElementById('TA').value)||0;document.getElementById('PO').innerHTML='+$'+Math.round(a*0.82)+' <span style="color:var(--txt2);font-size:10px">(82%)</span>';}
function setDur(el,s){document.querySelectorAll('.dur').forEach(d=>d.classList.remove('on'));el.classList.add('on');selDur=s;}

const pool={};
function poolKey(a,d){return a+'_'+d;}
function shouldWin(dir,a,d){
  const k=poolKey(a,d),p=pool[k];
  if(!p||(p.c+p.p)===0)return Math.random()>0.5;
  const total=p.c+p.p,callPct=p.c/total;
  const noise=(Math.random()-0.5)*0.1;
  const wp=dir==='CALL'?(1-callPct)+noise:(callPct)+noise;
  return Math.random()<Math.max(0.15,Math.min(0.85,wp));
}

function fmtTime(s){if(s<=0)return'0s';if(s<60)return s+'s';if(s<3600){const m=Math.floor(s/60),r=s%60;return r?m+'m '+r+'s':m+'m';}if(s<86400){const h=Math.floor(s/3600),m=Math.floor((s%3600)/60);return m?h+'h '+m+'m':h+'h';}if(s<604800){const d=Math.floor(s/86400),h=Math.floor((s%86400)/3600);return h?d+'d '+h+'h':d+'d';}const w=Math.floor(s/604800),d=Math.floor((s%604800)/86400);return d?w+'w '+d+'d':w+'w';}
function fmtDur(s){const m={30:'30s',60:'1m',120:'2m',240:'4m',600:'10m',900:'15m',1800:'30m',3600:'1h',7200:'2h',86400:'1D',604800:'1W',2592000:'1M'};return m[s]||s+'s';}
function fmtExp(s){const e=new Date(Date.now()+s*1000);if(s<86400)return e.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});if(s<604800)return e.toLocaleDateString([],{weekday:'short',day:'numeric',month:'short'})+' '+e.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});return e.toLocaleDateString([],{day:'numeric',month:'short',year:'numeric'});}

function placeTrade(dir){
  const amt=parseFloat(document.getElementById('TA').value);
  if(!amt||amt<1){toast('Minimum $1','lose');return;}
  if(amt>bal){toast('Insufficient balance!','lose');return;}
  bal-=amt;trades++;updBal();saveBal();
  const k=poolKey(asset,selDur);
  if(!pool[k])pool[k]={c:0,p:0};
  if(dir==='CALL')pool[k].c++;else pool[k].p++;
  // Simulate bots
  const bots=50+Math.floor(Math.random()*100),cp=0.3+Math.random()*0.4;
  pool[k].c+=Math.round(bots*cp);pool[k].p+=Math.round(bots*(1-cp));
  const t={id:Date.now(),asset,dir,amt,entry:price,timer:selDur,rem:selDur,lp:price,dl:fmtDur(selDur)};
  aTs.push(t);tCharts[t.id]=[price];tState[t.id]={z:1,o:0};
  renderActive();
  const total=pool[k].c+pool[k].p,cp2=Math.round(pool[k].c/total*100);
  toast(dir+' · '+fmtDur(selDur),'info');
  setTimeout(()=>toast('📊 '+cp2+'% CALL · '+(100-cp2)+'% PUT','info'),900);
  const iv=setInterval(()=>{t.rem--;renderActive();if(t.rem<=0){clearInterval(iv);resolveT(t);}},1000);
}

function resolveT(t){
  aTs=aTs.filter(x=>x.id!==t.id);
  const k=poolKey(t.asset,t.timer);
