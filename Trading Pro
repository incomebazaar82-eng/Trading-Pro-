// ===================== PRICE UPDATE =====================
function updPrice(){
  const vol=asset.includes('BTC')?20:asset.includes('ETH')?20:asset.includes('GOLD')?20:asset==='OIL'?20:asset.includes('JPY')?0.08:0.00055;
  price=Math.max(0.0001,price+(Math.random()-0.48)*vol*2);
  const up=candles.length>0&&price>=candles[candles.length-1].c;
  const last=candles[candles.length-1];
  if(Math.random()<0.12){candles.push({o:last.c,c:price,h:Math.max(last.c,price)+vol*0.3,l:Math.min(last.c,price)-vol*0.3});if(candles.length>200)candles.shift();}
  else{last.c=price;last.h=Math.max(last.h,price);last.l=Math.min(last.l,price);}
  const dec=getDec(asset);
  const pn=document.getElementById('PN');if(pn){pn.textContent=price.toFixed(dec);pn.className='pnum '+(up?'up':'dn');}
  const pb=document.getElementById('PB');const pct=((Math.random()*0.4)*(up?1:-1)).toFixed(2);
  if(pb){pb.textContent=(up?'▲ +':'▼ ')+pct+'%';pb.className='pbadge '+(up?'up':'dn');}
  const ir=document.getElementById('iR');if(ir){const r=(38+Math.random()*44).toFixed(1);ir.textContent=r;ir.style.color=r>70?'#ff1744':r<30?'#00e676':'#ffca28';}
  const im=document.getElementById('iM');if(im){const mv=((Math.random()-0.5)*0.012).toFixed(4);im.textContent=(mv>0?'+':'')+mv;im.style.color=mv>0?'#00e676':'#ff1744';}
  const dec2=getDec(asset);
  const m7=document.getElementById('iM7');if(m7)m7.textContent=(price*0.9996).toFixed(dec2);
  const m25=document.getElementById('iM25');if(m25)m25.textContent=(price*0.9992).toFixed(dec2);
  drawChart();
  // Update active trades
  aTs.forEach(t=>{
    if(t.asset===asset)t.lp=price;
    else{if(!t.lp)t.lp=t.entry;const v2=t.asset.includes('BTC')?200:t.asset.includes('ETH')?20:2;t.lp=Math.max(0.0001,t.lp+(Math.random()-0.48)*v2*1.5);}
    if(tCharts[t.id]){tCharts[t.id].push(t.lp);if(tCharts[t.id].length>200)tCharts[t.id].shift();drawMini(t.id);}
  });
  updAssetPrices();
  // Fluctuate sentiment
  ASSETS.forEach(a=>{if(sentiment[a.n]){sentiment[a.n].c=Math.max(20,Math.min(80,sentiment[a.n].c+Math.floor((Math.random()-0.5)*6)));}});
  updSent();
}

