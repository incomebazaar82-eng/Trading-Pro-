// ===================== MINI CHART =====================
function drawMini(id){
  const cv=document.getElementById('mc'+id);if(!cv)return;
  const data=tCharts[id];if(!data||data.length<2)return;
  const st=tState[id]||{z:1,o:0};
  const t=aTs.find(x=>x.id===id);
  const ctx=cv.getContext('2d'),W=cv.offsetWidth||250,H=85;
  cv.width=W;cv.height=H;ctx.clearRect(0,0,W,H);
  ctx.fillStyle='rgba(4,8,15,0.6)';ctx.fillRect(0,0,W,H);
  const vis=Math.max(5,Math.min(Math.floor(data.length/st.z),data.length));
  const end=Math.max(vis,data.length-Math.max(0,st.o)),start=Math.max(0,end-vis);
  const d=data.slice(start,end);if(d.length<2)return;
  const mn=Math.min(...d),mx=Math.max(...d),rng=mx-mn||0.0001,pad=5;
  const toY=v=>pad+(1-(v-mn)/rng)*(H-pad*2);
  ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;
  for(let i=1;i<3;i++){ctx.beginPath();ctx.moveTo(0,H*i/3);ctx.lineTo(W,H*i/3);ctx.stroke();}
  if(t){const ey=toY(t.entry);if(ey>0&&ey<H){ctx.setLineDash([4,4]);ctx.strokeStyle='rgba(255,202,40,0.6)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(0,ey);ctx.lineTo(W,ey);ctx.stroke();ctx.setLineDash([]);}}
  const isUp=d[d.length-1]>=(t?t.entry:d[0]),lc=isUp?'#00e676':'#ff1744';
  ctx.beginPath();d.forEach((v,i)=>{const x=i/(d.length-1)*W;i===0?ctx.moveTo(x,toY(v)):ctx.lineTo(x,toY(v));});
  ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
  const gr=ctx.createLinearGradient(0,0,0,H);gr.addColorStop(0,isUp?'rgba(0,230,118,0.2)':'rgba(255,23,68,0.2)');gr.addColorStop(1,'rgba(0,0,0,0)');ctx.fillStyle=gr;ctx.fill();
  ctx.beginPath();d.forEach((v,i)=>{const x=i/(d.length-1)*W;i===0?ctx.moveTo(x,toY(v)):ctx.lineTo(x,toY(v));});
  ctx.strokeStyle=lc;ctx.lineWidth=2;ctx.stroke();
  const lx=W-2,ly=toY(d[d.length-1]);
  ctx.beginPath();ctx.arc(lx,ly,4,0,Math.PI*2);ctx.fillStyle=lc;ctx.shadowColor=lc;ctx.shadowBlur=8;ctx.fill();ctx.shadowBlur=0;
  const dec=getDec(t?t.asset:asset);
  ctx.fillStyle=lc;ctx.fillRect(W-54,ly-9,53,17);ctx.fillStyle='#000';ctx.font='bold 8px Orbitron,monospace';ctx.textAlign='center';ctx.fillText(d[d.length-1].toFixed(dec),W-28,ly+3);
  if(st.z!==1){ctx.fillStyle='rgba(0,180,255,0.7)';ctx.font='8px Exo 2,sans-serif';ctx.textAlign='left';ctx.fillText('🔍'+Math.round(st.z*100)+'%',3,H-3);}
}

function setupMini(id){
  const cv=document.getElementById('mc'+id);
  if(!cv) return;
  if(!tState[id]) tState[id]={z:1,o:0};
  const st=tState[id];
  let dx=0,dOff=0,drag=false,sy=0,pd=0,pz=1;
  let gestureType=null; // 'h'=horizontal pan, 'v'=vertical, 'pinch'

  // Mouse events
  cv.addEventListener('mousedown',e=>{
    drag=true;dx=e.clientX;sy=e.clientY;dOff=st.o;
    gestureType=null;
    e.stopPropagation();
  });
  window.addEventListener('mousemove',e=>{
    if(!drag)return;
    const ddx=e.clientX-dx,ddy=e.clientY-sy;
    if(!gestureType) gestureType=Math.abs(ddx)>Math.abs(ddy)?'h':'v';
    if(gestureType==='h'){
      const W=cv.offsetWidth||250,vis=Math.max(5,(tCharts[id]||[]).length),cw=W/vis;
      st.o=Math.max(0,Math.min(dOff+Math.round(-ddx/cw),(tCharts[id]||[]).length-5));
      drawMini(id);
    } else if(gestureType==='v'){
      const f=ddy<0?1.025:0.975;
      st.z=Math.max(0.2,Math.min(8,st.z*f));
      drawMini(id);
    }
  });
  window.addEventListener('mouseup',()=>{drag=false;gestureType=null;});

  cv.addEventListener('wheel',e=>{
    e.preventDefault();e.stopPropagation();
    st.z=Math.max(0.2,Math.min(8,st.z*(e.deltaY<0?1.2:0.83)));
    drawMini(id);
  },{passive:false});

  // Touch events — smart gesture detection
  cv.addEventListener('touchstart',e=>{
    gestureType=null;
    if(e.touches.length===1){
      drag=true;
      dx=e.touches[0].clientX;
      sy=e.touches[0].clientY;
      dOff=st.o;
    } else if(e.touches.length===2){
      drag=false;
      gestureType='pinch';
      const ddx=e.touches[0].clientX-e.touches[1].clientX;
      const ddy=e.touches[0].clientY-e.touches[1].clientY;
      pd=Math.sqrt(ddx*ddx+ddy*ddy);
      pz=st.z;
      e.preventDefault(); // only block on pinch
    }
    e.stopPropagation();
  },{passive:false});

  cv.addEventListener('touchmove',e=>{
    if(e.touches.length===2){
      // Pinch zoom — always handle
      const ddx=e.touches[0].clientX-e.touches[1].clientX;
      const ddy=e.touches[0].clientY-e.touches[1].clientY;
      const dist=Math.sqrt(ddx*ddx+ddy*ddy);
      st.z=Math.max(0.2,Math.min(8,pz*dist/pd));
      drawMini(id);
      e.preventDefault();
      e.stopPropagation();
      return;
    }

    if(e.touches.length===1&&drag){
      const ddx=e.touches[0].clientX-dx;
      const ddy=e.touches[0].clientY-sy;

      // Determine gesture direction on first move
      if(!gestureType){
        if(Math.abs(ddx)>Math.abs(ddy)+5) gestureType='h';
        else if(Math.abs(ddy)>Math.abs(ddx)+5) gestureType='v';
        else return; // not decided yet
      }

      if(gestureType==='h'){
        // Horizontal → pan chart, block page scroll
        const W=cv.offsetWidth||250;
        const vis=Math.max(5,(tCharts[id]||[]).length);
        const cw=W/vis;
        st.o=Math.max(0,Math.min(dOff+Math.round(-ddx/cw),(tCharts[id]||[]).length-5));
        drawMini(id);
        e.preventDefault();
        e.stopPropagation();
      }
      // gestureType==='v' → let page scroll naturally (no preventDefault)
    }
  },{passive:false});

  cv.addEventListener('touchend',()=>{drag=false;gestureType=null;});

  // Double tap to reset
  let lt=0;
  cv.addEventListener('click',e=>{
    const now=Date.now();
    if(now-lt<300){st.z=1;st.o=0;drawMini(id);toast('↺ Chart Reset','info');}
    lt=now;
    e.stopPropagation();
  });
}

// ===================== RENDER ACTIVE =====================
function renderActive(){
  const c=document.getElementById('AT');
  if(!c) return;

  // No trades
  if(!aTs.length){
    c.innerHTML='<div class="empty-msg">No active trades</div>';
    return;
  }

  // Remove "No active trades" message if present
  const empty=c.querySelector('.empty-msg');
  if(empty) empty.remove();

  // For each trade — create card if not exist, update data only (not innerHTML)
  aTs.forEach(t=>{
    const dec=getDec(t.asset);
    const curP=t.lp||t.entry;
    const pnl=(curP-t.entry)*(t.dir==='CALL'?1:-1);
    const pnlPct=(pnl/t.entry*100).toFixed(3);
    const col=pnl>=0?'var(--green)':'var(--red)';
    const pct=Math.min(100,Math.round((t.timer-t.rem)/t.timer*100));
    const winning=(t.dir==='CALL'&&pnl>=0)||(t.dir==='PUT'&&pnl<0);
    const sc=winning?'var(--green)':'var(--red)';
    const st=winning?'✅ Winning':'❌ Losing';

    // Check if card exists
    let card=document.getElementById('c'+t.id);

    if(!card){
      // CREATE full card HTML once
      card=document.createElement('div');
      card.className='tcard';
      card.id='c'+t.id;
      card.innerHTML=`
        <div class="tcard-top">
          <div class="tdir ${t.dir==='CALL'?'up':'dn'}">${t.dir==='CALL'?'▲':'▼'}</div>
          <div class="tinfo">
            <div class="tname">${t.asset} · <span style="color:var(--gold);font-size:10px">${t.dl}</span></div>
            <div class="tmeta" id="tm${t.id}">Entry: ${t.entry.toFixed(dec)}</div>
          </div>
          <div class="tstatus">
            <div class="tstatus-txt" id="ts${t.id}" style="color:${sc}">${st}</div>
            <div class="ttimer" id="tt${t.id}">${fmtTime(t.rem)}</div>
          </div>
        </div>
        <div class="mini-cwrap" id="mw${t.id}">
          <canvas class="mini-cv" id="mc${t.id}"></canvas>
          <div class="mini-hint">pinch/swipe=zoom · drag=scroll · 2x tap=reset</div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:5px">
          <div style="font-size:10px;color:var(--txt2)" id="te${t.id}">⏱ ${fmtExp(t.rem)}</div>
          <div style="font-family:'Orbitron',monospace;font-size:10px;color:var(--gold)">$${t.amt}</div>
        </div>
        <div class="tprog"><div class="tbar" id="tb${t.id}" style="width:0%;background:var(--green)"></div></div>
      `;
      c.appendChild(card);

      // Setup mini chart ONCE after card is in DOM
      setTimeout(()=>{
        if(tCharts[t.id]) drawMini(t.id);
        setupMini(t.id);
      },30);
    }

    // UPDATE only the changing parts (no innerHTML reassign on existing cards)
    const tmEl=document.getElementById('tm'+t.id);
    if(tmEl) tmEl.innerHTML=`Entry: ${t.entry.toFixed(dec)} · Now: <span style="color:${col}">${curP.toFixed(dec)}</span> <span style="color:${col}">(${pnl>=0?'+':''}${pnlPct}%)</span>`;

    const tsEl=document.getElementById('ts'+t.id);
    if(tsEl){tsEl.textContent=st;tsEl.style.color=sc;}

    const ttEl=document.getElementById('tt'+t.id);
    if(ttEl) ttEl.textContent=fmtTime(t.rem);

    const teEl=document.getElementById('te'+t.id);
    if(teEl) teEl.textContent='⏱ '+fmtExp(t.rem);

    const tbEl=document.getElementById('tb'+t.id);
    if(tbEl){tbEl.style.width=pct+'%';tbEl.style.background=winning?'var(--green)':'var(--red)';}
  });

  // Remove cards for resolved trades
  const activeIds=aTs.map(t=>'c'+t.id);
  c.querySelectorAll('.tcard').forEach(card=>{
    if(!activeIds.includes(card.id)) card.remove();
  });

  // If somehow empty
  if(!c.querySelector('.tcard') && !c.querySelector('.empty-msg')){
    c.innerHTML='<div class="empty-msg">No active trades</div>';
  }
}

