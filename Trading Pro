function toast(m,t){const e=document.getElementById('T');e.textContent=m;e.className='toast '+t+' show';clearTimeout(e._t);e._t=setTimeout(()=>e.classList.remove('show'),3000);}

// ===================== AUTH =====================
let USERS=JSON.parse(localStorage.getItem('TX_U')||'[]');

function sw(id){document.querySelectorAll('.auth-sc').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');}
function tpw(id,ic){const e=document.getElementById(id);if(!e)return;e.type=e.type==='password'?'text':'password';ic.textContent=e.type==='password'?'👁':'🙈';}
function pwStr(pw){
  const bs=[1,2,3,4].map(i=>document.getElementById('pb'+i));
  const h=document.getElementById('pwH');
  bs.forEach(b=>{if(b)b.className='pw-bar';});
  if(!pw){if(h){h.textContent='Enter a password';h.style.color='var(--txt2)';}return;}
  let s=0;if(pw.length>=8)s++;if(/[A-Z]/.test(pw))s++;if(/[0-9]/.test(pw))s++;if(/[^A-Za-z0-9]/.test(pw))s++;
  const i=Math.max(0,s-1),cls=['w','w','f','s'],lb=['Too short','Weak','Fair','Strong 💪'],col=['var(--red)','var(--red)','var(--gold)','var(--green)'];
  for(let j=0;j<s;j++)if(bs[j])bs[j].classList.add(cls[i]);
  if(h){h.textContent=lb[i];h.style.color=col[i];}
  chkM();
}
function chkM(){
  const p=document.getElementById('SP').value,c=document.getElementById('SC').value,h=document.getElementById('mH');
  if(!h||!c)return;
  h.textContent=p===c?'✅ Passwords match':'❌ Do not match';
  h.style.color=p===c?'var(--green)':'var(--red)';
}
function doLogin(){
  const em=document.getElementById('LE').value.trim(),pw=document.getElementById('LP').value;
  if(!em||!pw){toast('Please fill all fields','lose');return;}
  if(!/\S+@\S+\.\S+/.test(em)){toast('Invalid email','lose');return;}
  const u=USERS.find(u=>u.e===em&&u.p===pw);
  if(!u){toast('❌ Wrong email or password','lose');return;}
  localStorage.setItem('TX_S',JSON.stringify({e:em,p:pw}));
