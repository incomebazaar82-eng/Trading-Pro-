<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>TradeX Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;}
:root{
  --bg:#04080f;--bg2:#080f1c;--bg3:#0c1624;--card:#0f1e30;
  --border:rgba(0,180,255,0.15);--green:#00e676;--red:#ff1744;
  --blue:#00b4ff;--gold:#ffca28;--purple:#c962ff;
  --txt:#ddeeff;--txt2:#5a8aaa;--nav:62px;
}
body{font-family:'Exo 2',sans-serif;background:var(--bg);color:var(--txt);max-width:430px;margin:0 auto;display:flex;flex-direction:column;height:100%;}

/* ===== TOAST ===== */
.toast{position:fixed;top:68px;left:50%;transform:translateX(-50%) translateY(-10px);background:var(--card);border-radius:12px;padding:10px 22px;font-family:'Orbitron',monospace;font-size:11px;font-weight:700;border:1.5px solid;opacity:0;transition:all 0.3s;z-index:9999;white-space:nowrap;pointer-events:none;max-width:92%;text-align:center;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast.win{border-color:var(--green);color:var(--green);box-shadow:0 0 18px rgba(0,230,118,0.35);}
.toast.lose{border-color:var(--red);color:var(--red);box-shadow:0 0 18px rgba(255,23,68,0.35);}
.toast.info{border-color:var(--blue);color:var(--blue);box-shadow:0 0 14px rgba(0,180,255,0.3);}

/* ===== AUTH ===== */
#authWrap{position:fixed;inset:0;z-index:900;background:var(--bg);overflow-y:auto;display:flex;flex-direction:column;align-items:center;}
#authWrap.gone{display:none;}
.a-orb{position:fixed;border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0;}
.a-orb1{width:280px;height:280px;background:#00b4ff;opacity:0.1;top:-60px;right:-60px;}
.a-orb2{width:240px;height:240px;background:#c962ff;opacity:0.1;bottom:0;left:-60px;}
.auth-box{position:relative;z-index:1;width:100%;max-width:400px;padding:0 20px 40px;}
.auth-logo{font-family:'Orbitron',monospace;font-size:30px;font-weight:900;background:linear-gradient(135deg,#00b4ff,#c962ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:4px;text-align:center;margin-top:48px;margin-bottom:4px;}
.auth-tag{font-size:12px;color:var(--txt2);letter-spacing:1.5px;text-align:center;margin-bottom:28px;}
.auth-card{width:100%;background:rgba(12,22,36,0.95);border:1.5px solid rgba(0,180,255,0.2);border-radius:22px;padding:24px 20px;margin-bottom:14px;box-shadow:0 8px 40px rgba(0,0,0,0.4);}
.auth-title{font-family:'Orbitron',monospace;font-size:18px;font-weight:700;margin-bottom:3px;}
.auth-sub{font-size:12px;color:var(--txt2);margin-bottom:20px;}
.inp-grp{margin-bottom:13px;}
.inp-lbl{font-size:10px;color:var(--txt2);text-transform:uppercase;letter-spacing:0.8px;font-weight:600;margin-bottom:5px;display:block;}
.inp-wrap{position:relative;}
.inp{width:100%;background:rgba(0,180,255,0.04);border:1.5px solid rgba(0,180,255,0.18);border-radius:12px;padding:12px 42px 12px 14px;color:var(--txt);font-family:'Exo 2',sans-serif;font-size:14px;outline:none;transition:all 0.25s;}
.inp::placeholder{color:var(--txt2);}
.inp:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(0,180,255,0.1);}
.inp-ico{position:absolute;right:13px;top:50%;transform:translateY(-50%);font-size:15px;color:var(--txt2);cursor:pointer;user-select:none;}
.pw-bars{display:flex;gap:4px;margin-top:5px;}
.pw-bar{flex:1;height:3px;border-radius:2px;background:rgba(255,255,255,0.08);transition:all 0.3s;}
.pw-bar.w{background:var(--red);}.pw-bar.f{background:var(--gold);}.pw-bar.s{background:var(--green);}
.pw-hint{font-size:10px;margin-top:3px;color:var(--txt2);}
.match-hint{font-size:10px;margin-top:3px;}
.rem-row{display:flex;align-items:center;gap:8px;margin-bottom:18px;cursor:pointer;}
.rem-box{width:18px;height:18px;border-radius:5px;border:1.5px solid rgba(0,180,255,0.3);background:rgba(0,180,255,0.04);display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;}
.rem-box.on{background:var(--blue);border-color:var(--blue);}
.rem-box.on::after{content:'✓';font-size:11px;color:#fff;font-weight:700;}
.rem-txt{font-size:12px;color:var(--txt2);}
.auth-btn{width:100%;padding:14px;border:none;border-radius:13px;font-family:'Orbitron',monospace;font-size:13px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all 0.2s;margin-bottom:13px;}
.auth-btn:active{transform:scale(0.97);}
.btn-blue{background:linear-gradient(135deg,#0060aa,#00b4ff);color:#fff;box-shadow:0 4px 18px rgba(0,180,255,0.3);}
.btn-green{background:linear-gradient(135deg,#006030,#00e676);color:#001808;box-shadow:0 4px 18px rgba(0,230,118,0.25);}
.auth-switch{text-align:center;font-size:13px;color:var(--txt2);}
.auth-switch a{color:var(--blue);font-weight:700;cursor:pointer;}
.auth-sc{display:none;width:100%;}
.auth-sc.active{display:block;}

/* ===== APP ===== */
#appWrap{display:none;flex-direction:column;height:100%;}
#appWrap.show{display:flex;}
.page{display:none;flex-direction:column;flex:1;overflow-y:auto;overflow-x:hidden;padding-bottom:var(--nav);scrollbar-width:none;}
.page::-webkit-scrollbar{display:none;}
.page.active{display:flex;}

/* Topbar */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:rgba(6,12,24,0.97);border-bottom:1.5px solid var(--border);position:sticky;top:0;z-index:50;backdrop-filter:blur(14px);flex-shrink:0;}
.tlogo{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;background:linear-gradient(90deg,#00b4ff,#c962ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:2px;}
.tright{display:flex;align-items:center;gap:10px;}
.nbtn{width:33px;height:33px;border-radius:50%;background:var(--card);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;font-size:14px;}
.ndot{width:7px;height:7px;border-radius:50%;background:var(--red);position:absolute;top:3px;right:3px;border:1.5px solid var(--bg);}
.balpill{background:rgba(255,202,40,0.1);border:1.5px solid rgba(255,202,40,0.3);border-radius:20px;padding:4px 12px;font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:var(--gold);cursor:pointer;}

/* Bottom nav */
.botnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;height:var(--nav);background:rgba(4,8,15,0.98);border-top:1.5px solid var(--border);display:flex;align-items:center;justify-content:space-around;z-index:100;backdrop-filter:blur(16px);}
.ni{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:6px 12px;border-radius:12px;transition:all 0.25s;flex:1;}
.ni-ico{font-size:21px;transition:all 0.25s;}
.ni-lbl{font-size:9px;font-weight:600;letter-spacing:0.5px;color:var(--txt2);text-transform:uppercase;transition:all 0.25s;}
.ni.on .ni-lbl{color:var(--blue);}
.ni.on .ni-ico{transform:translateY(-2px);filter:drop-shadow(0 0 7px var(--blue));}
.nc{width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,#0080cc,#00b4ff,#c962ff);display:flex;align-items:center;justify-content:center;font-size:22px;cursor:pointer;margin-top:-20px;box-shadow:0 4px 22px rgba(0,180,255,0.45);border:3px solid var(--bg);transition:all 0.2s;flex-shrink:0;}
.nc:active{transform:scale(0.92);}

/* Pulse dot */
.pdot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pls 1.4s infinite;box-shadow:0 0 8px rgba(0,230,118,0.6);}
@keyframes pls{0%,100%{opacity:1;}50%{opacity:0.3;}}

/* ===== TRADE PAGE ===== */
.asset-bar{display:flex;gap:7px;padding:8px 12px;background:var(--bg2);border-bottom:1.5px solid var(--border);overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
.asset-bar::-webkit-scrollbar{display:none;}
.achip{flex-shrink:0;padding:5px 12px;border-radius:16px;border:1.5px solid rgba(0,180,255,0.15);background:transparent;color:var(--txt2);font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;font-family:'Exo 2',sans-serif;}
.achip.on{background:rgba(0,180,255,0.12);border-color:var(--blue);color:var(--blue);box-shadow:0 0 12px rgba(0,180,255,0.2);}

/* Price row */
.price-compact{display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--bg2);border-bottom:1.5px solid var(--border);flex-shrink:0;}
.price-left{display:flex;align-items:center;gap:8px;flex:1;}
.pnum{font-family:'Orbitron',monospace;font-size:24px;font-weight:700;}
.pnum.up{color:var(--green);text-shadow:0 0 16px rgba(0,230,118,0.5);}
.pnum.dn{color:var(--red);text-shadow:0 0 16px rgba(255,23,68,0.5);}
.pbadge{font-size:11px;font-weight:700;padding:3px 9px;border-radius:9px;}
.pbadge.up{background:rgba(0,230,118,0.12);color:var(--green);}
.pbadge.dn{background:rgba(255,23,68,0.12);color:var(--red);}
.price-right{display:flex;flex-direction:column;align-items:flex-end;gap:2px;}
.liverow{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--txt2);}
.tfs-inline{display:flex;gap:4px;flex-shrink:0;}
.tf{padding:3px 9px;border-radius:7px;font-size:10px;font-weight:700;cursor:pointer;border:1px solid rgba(0,180,255,0.2);background:rgba(8,15,28,0.85);color:var(--txt2);transition:all 0.2s;}
.tf.on{background:var(--blue);color:#fff;border-color:var(--blue);}

/* Chart */
.cwrap{position:relative;background:var(--bg3);flex-shrink:0;padding-top:18px;padding-bottom:18px;}
.chint{position:absolute;left:0;right:0;height:18px;display:flex;align-items:center;justify-content:center;font-size:9px;color:rgba(0,180,255,0.4);letter-spacing:0.5px;pointer-events:none;font-family:'Exo 2',sans-serif;}
.chint.top{top:0;background:rgba(0,180,255,0.04);border-bottom:1px dashed rgba(0,180,255,0.1);}
.chint.bot{bottom:0;background:rgba(0,180,255,0.04);border-top:1px dashed rgba(0,180,255,0.1);}
#MC{width:100%;height:210px;display:block;cursor:grab;touch-action:none;}
#MC:active{cursor:grabbing;}

/* Indicators */
.indbar{display:flex;background:var(--bg2);border-bottom:1.5px solid var(--border);overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
.indbar::-webkit-scrollbar{display:none;}
.icell{flex-shrink:0;padding:6px 14px;border-right:1px solid rgba(0,180,255,0.1);text-align:center;}
.iname{font-size:9px;color:var(--txt2);text-transform:uppercase;letter-spacing:0.5px;}
.ival{font-family:'Orbitron',monospace;font-size:11px;font-weight:600;}

/* Trade bottom */
.tbottom{background:var(--bg2);border-top:1.5px solid var(--border);padding:8px 10px;flex-shrink:0;}
.tb-row1{display:flex;gap:8px;align-items:center;margin-bottom:7px;}
.tb-amt-w{flex:1;}
.tb-lbl{font-size:9px;color:var(--txt2);text-transform:uppercase;letter-spacing:0.5px;display:block;margin-bottom:4px;}
.tb-amtrow{display:flex;align-items:center;gap:4px;}
.tb-pm{width:30px;height:34px;border-radius:8px;background:rgba(0,180,255,0.1);border:1.5px solid rgba(0,180,255,0.2);color:var(--blue);font-size:20px;font-weight:700;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all 0.15s;user-select:none;}
.tb-pm:active{background:rgba(0,180,255,0.25);transform:scale(0.92);}
.tb-amtinp{flex:1;background:rgba(0,0,0,0.3);border:1.5px solid var(--border);border-radius:8px;padding:6px 4px;color:var(--txt);font-family:'Orbitron',monospace;font-size:16px;font-weight:700;text-align:center;outline:none;height:34px;}
.tb-pay{flex-shrink:0;}
.tb-paybox{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;color:var(--green);background:rgba(0,230,118,0.08);border:1.5px solid rgba(0,230,118,0.2);border-radius:8px;padding:6px 10px;height:34px;display:flex;align-items:center;gap:4px;}
.tb-qrow{display:flex;gap:4px;margin-bottom:7px;}
.tb-q{flex:1;padding:5px 2px;border-radius:7px;border:1.5px solid rgba(0,180,255,0.15);background:rgba(0,180,255,0.04);color:var(--blue);font-size:10px;font-weight:700;cursor:pointer;text-align:center;transition:all 0.15s;}
.tb-q:active{background:rgba(0,180,255,0.2);}
.tb-durs{display:flex;gap:4px;margin-bottom:7px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;}
.tb-durs::-webkit-scrollbar{display:none;}
.dur{flex:0 0 auto;padding:5px 10px;border-radius:7px;border:1.5px solid rgba(0,180,255,0.15);background:transparent;color:var(--txt2);font-size:11px;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.dur.on{background:rgba(201,98,255,0.15);border-color:var(--purple);color:var(--purple);}
.tb-sentrow{display:flex;align-items:center;gap:6px;margin-bottom:8px;}
.sent-bar{flex:1;height:6px;border-radius:6px;overflow:hidden;background:rgba(255,255,255,0.05);display:flex;}
.sc{background:linear-gradient(90deg,#00b04a,#00e676);transition:width 0.5s;}
.sp{background:linear-gradient(90deg,#ff1744,#b50000);transition:width 0.5s;}
.sc-lbl{font-size:11px;font-weight:700;color:var(--green);flex-shrink:0;}
.sp-lbl{font-size:11px;font-weight:700;color:var(--red);flex-shrink:0;}
.tb-btnrow{display:flex;gap:8px;}
.bcall,.bput{flex:1;padding:12px 8px;border-radius:14px;border:none;cursor:pointer;transition:all 0.15s;display:flex;flex-direction:column;align-items:center;gap:2px;}
.bcall{background:linear-gradient(135deg,#006030,#00e676);box-shadow:0 4px 20px rgba(0,230,118,0.35);}
.bput{background:linear-gradient(135deg,#8a0000,#ff1744);box-shadow:0 4px 20px rgba(255,23,68,0.35);}
.bcall:active,.bput:active{transform:scale(0.96);}
.btn-arrow{font-size:22px;line-height:1;}
.btn-lbl{font-family:'Orbitron',monospace;font-size:14px;font-weight:900;color:#fff;letter-spacing:2px;}
.bcall .btn-lbl{color:#001808;}
.btn-pct{font-size:10px;font-weight:600;color:rgba(0,0,0,0.5);}
.bput .btn-pct{color:rgba(255,200,200,0.7);}

/* Active trades */
.section{padding:12px;background:var(--bg2);border-bottom:1.5px solid var(--border);}
.sec-title{font-size:10px;color:var(--txt2);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;font-weight:600;}
.tcard{background:var(--card);border-radius:12px;padding:11px;margin-bottom:8px;border:1.5px solid var(--border);display:flex;flex-direction:column;gap:7px;animation:fadeIn 0.3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}
.tcard-top{display:flex;align-items:center;gap:10px;}
.tdir{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.tdir.up{background:rgba(0,230,118,0.12);}
.tdir.dn{background:rgba(255,23,68,0.12);}
.tinfo{flex:1;}
.tname{font-size:13px;font-weight:700;}
.tmeta{font-size:10px;color:var(--txt2);}
.tstatus{text-align:right;}
.tstatus-txt{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;}
.ttimer{font-size:10px;color:var(--purple);}

/* Mini chart */
.mini-cwrap{background:rgba(0,0,0,0.35);border-radius:10px;overflow:hidden;border:1.5px solid rgba(0,180,255,0.15);position:relative;touch-action:pan-y;cursor:crosshair;}
.mini-cv{display:block;width:100%;height:85px;}
.mini-hint{position:absolute;bottom:3px;right:5px;font-size:8px;color:rgba(255,255,255,0.2);pointer-events:none;font-family:'Exo 2',sans-serif;}
.tprog{height:3px;background:rgba(255,255,255,0.05);border-radius:2px;overflow:hidden;}
.tbar{height:100%;border-radius:2px;transition:width 1s linear;}
.empty-msg{text-align:center;color:var(--txt2);font-size:12px;padding:14px;}

/* ===== ASSETS PAGE ===== */
.filtbar{display:flex;gap:6px;padding:9px 12px;background:var(--bg2);border-bottom:1.5px solid var(--border);overflow-x:auto;scrollbar-width:none;flex-shrink:0;}
.filtbar::-webkit-scrollbar{display:none;}
.filt{flex-shrink:0;padding:5px 14px;border-radius:14px;border:1.5px solid rgba(0,180,255,0.15);background:transparent;color:var(--txt2);font-size:11px;font-weight:600;cursor:pointer;transition:all 0.2s;}
.filt.on{background:rgba(201,98,255,0.12);border-color:var(--purple);color:var(--purple);}
.alist{flex:1;overflow-y:auto;padding:9px;}
.arow{display:flex;align-items:center;gap:12px;background:var(--card);border-radius:13px;padding:13px;margin-bottom:8px;border:1.5px solid var(--border);cursor:pointer;transition:all 0.2s;}
.arow:active{background:rgba(0,180,255,0.06);}
.aico{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.ainfo{flex:1;}
.aname{font-size:14px;font-weight:700;}
.asub{font-size:11px;color:var(--txt2);}
.aright{text-align:right;}
.aprice{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;}
.achg{font-size:11px;font-weight:600;padding:2px 7px;border-radius:8px;margin-top:2px;display:inline-block;}
.cup{background:rgba(0,230,118,0.1);color:var(--green);}
.cdn{background:rgba(255,23,68,0.1);color:var(--red);}

/* ===== HISTORY ===== */
.htabs{display:flex;background:var(--bg2);border-bottom:1.5px solid var(--border);flex-shrink:0;}
.htab{flex:1;padding:11px;text-align:center;font-size:12px;font-weight:700;color:var(--txt2);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;}
.htab.on{color:var(--blue);border-bottom-color:var(--blue);}
.hlist{flex:1;overflow-y:auto;padding:9px;}
.hitem{display:flex;align-items:center;gap:11px;background:var(--card);border-radius:12px;padding:12px;margin-bottom:8px;border:1.5px solid var(--border);}
.hico{width:35px;height:35px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.hico.win{background:rgba(0,230,118,0.1);}.hico.loss{background:rgba(255,23,68,0.1);}
.hico.dep{background:rgba(0,180,255,0.1);}.hico.wit{background:rgba(201,98,255,0.1);}
.hinfo{flex:1;}
.htitle{font-size:13px;font-weight:700;}
.hsub{font-size:10px;color:var(--txt2);}
.hamt{font-family:'Orbitron',monospace;font-size:13px;font-weight:700;}
.hbadge{font-size:10px;padding:2px 7px;border-radius:6px;font-weight:600;display:inline-block;margin-top:3px;}
.bwin{background:rgba(0,230,118,0.1);color:var(--green);}
.bloss{background:rgba(255,23,68,0.1);color:var(--red);}
.bok{background:rgba(0,230,118,0.1);color:var(--green);}
.bpend{background:rgba(255,202,40,0.1);color:var(--gold);}

/* ===== PROFILE ===== */
.phero{background:linear-gradient(135deg,#0b1d33,#0e1c2e);padding:20px 14px;border-bottom:1.5px solid var(--border);flex-shrink:0;}
.ptop{display:flex;align-items:center;gap:14px;margin-bottom:16px;}
.pavatar{width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;border:2px solid rgba(0,180,255,0.3);}
.pname{font-size:18px;font-weight:700;}
.pid{font-size:11px;color:var(--txt2);}
.plevel{display:inline-flex;align-items:center;gap:4px;background:rgba(255,202,40,0.1);border:1px solid rgba(255,202,40,0.25);border-radius:10px;padding:2px 9px;font-size:10px;color:var(--gold);font-weight:600;margin-top:4px;}
.scards{display:flex;gap:8px;}
.scard{flex:1;background:rgba(0,0,0,0.25);border:1.5px solid var(--border);border-radius:13px;padding:10px;}
.slbl{font-size:10px;color:var(--txt2);text-transform:uppercase;letter-spacing:0.5px;}
.sval{font-family:'Orbitron',monospace;font-size:14px;font-weight:700;color:var(--gold);margin-top:2px;}
