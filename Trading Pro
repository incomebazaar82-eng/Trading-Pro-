function getDec(n){if(n.includes('BTC'))return 0;if(n.includes('JPY'))return 2;if(['ETH','GOLD','SILVER','BNB','SOL','APPLE','TESLA','GOOGLE','OIL'].some(x=>n.includes(x)))return 1;return 5;}

function initCandles(){
  candles=[];let p=price;
  for(let i=0;i<150;i++){let o=p,c=o+(Math.random()-0.49)*p*0.003;candles.push({o,c,h:Math.max(o,c)+Math.random()*p*0.001,l:Math.min(o,c)-Math.random()*p*0.001});p=c;}
  cZoom=1;cOff=0;
}

function getVis(){
  const cv=document.getElementById('MC');if(!cv)return{data:[],s:0};
  const W=cv.offsetWidth||350,vis=Math.max(5,Math.min(Math.floor(W/8/cZoom*8),candles.length));
  const end=Math.max(vis,candles.length-Math.max(0,cOff)),start=Math.max(0,end-vis);
  return{data:candles.slice(start,end),s:start};
}

function drawChart(){
  const cv=document.getElementById('MC');if(!cv)return;
  const ctx=cv.getContext('2d'),dpr=window.devicePixelRatio||1,W=cv.offsetWidth,H=210;
  cv.width=W*dpr;cv.height=H*dpr;ctx.scale(dpr,dpr);
  ctx.clearRect(0,0,W,H);
  const bg=ctx.createLinearGradient(0,0,0,H);bg.addColorStop(0,'#0c1624');bg.addColorStop(1,'#04080f');
  ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);
  ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;
  for(let i=1;i<5;i++){ctx.beginPath();ctx.moveTo(0,H*i/5);ctx.lineTo(W,H*i/5);ctx.stroke();}
  const{data:v}=getVis();if(v.length<2)return;
  const all=v.flatMap(c=>[c.h,c.l]),mn=Math.min(...all),mx=Math.max(...all),rng=mx-mn||0.0001;
  const pL=8,pR=48,pT=8,pB=18,toY=val=>pT+(1-(val-mn)/rng)*(H-pT-pB);
  const cw=(W-pL-pR)/v.length,bw=Math.max(1,cw*0.55);
  // Price labels
  ctx.fillStyle='rgba(90,138,170,0.8)';ctx.font='9px Orbitron,monospace';ctx.textAlign='right';
  for(let i=0;i<=4;i++){const val=mn+(mx-mn)*i/4;ctx.fillText(val.toFixed(getDec(asset)),W-2,toY(val)+3);}
  v.forEach((c,i)=>{
    const x=pL+i*cw+cw/2,up=c.c>=c.o;
    ctx.strokeStyle=up?'#00e676':'#ff1744';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(x,toY(c.h));ctx.lineTo(x,toY(c.l));ctx.stroke();
    const bt=toY(Math.max(c.o,c.c)),bh=Math.max(1,Math.abs(toY(c.o)-toY(c.c)));
    ctx.fillStyle=up?'rgba(0,230,118,0.88)':'rgba(255,23,68,0.88)';ctx.fillRect(x-bw/2,bt,bw,bh);
  });
  const ly=toY(v[v.length-1].c),isUp=v[v.length-1].c>=v[0].o;
  ctx.setLineDash([3,4]);ctx.strokeStyle=isUp?'rgba(0,230,118,0.5)':'rgba(255,23,68,0.5)';ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(0,ly);ctx.lineTo(W-pR,ly);ctx.stroke();ctx.setLineDash([]);
  // Price tag
  const tc=isUp?'#00e676':'#ff1744';ctx.fillStyle=tc;ctx.fillRect(W-pR+2,ly-9,pR-2,18);
  ctx.fillStyle='#000';ctx.font='bold 8px Orbitron,monospace';ctx.textAlign='center';
  ctx.fillText(v[v.length-1].c.toFixed(getDec(asset)),W-pR/2+1,ly+3);
  // LIVE/HIST
  if(cOff===0){ctx.fillStyle='rgba(0,230,118,0.8)';ctx.fillRect(pL,4,26,14);ctx.fillStyle='#001808';ctx.font='bold 8px Arial';ctx.textAlign='left';ctx.fillText('LIVE',pL+2,14);}
  else{ctx.fillStyle='rgba(255,202,40,0.8)';ctx.fillRect(pL,4,32,14);ctx.fillStyle='#1a0e00';ctx.font='bold 8px Arial';ctx.textAlign='left';ctx.fillText('HIST',pL+2,14);}
}

function setupChart(){
  const cv=document.getElementById('MC');if(!cv)return;
  const nc=cv.cloneNode(true);cv.parentNode.replaceChild(nc,cv);
  const c=document.getElementById('MC');
  c.addEventListener('mousedown',e=>{isDrag=true;dragX=e.clientX;dragOff=cOff;c.style.cursor='grabbing';e.preventDefault();});
  window.addEventListener('mousemove',e=>{
    if(!isDrag)return;
    const W=c.offsetWidth||350,{data:v}=getVis(),cw=W/Math.max(v.length,1);
    const d=Math.round(-(e.clientX-dragX)/cw);
    cOff=Math.max(0,Math.min(dragOff+d,candles.length-5));drawChart();
  });
  window.addEventListener('mouseup',()=>{if(isDrag){isDrag=false;c.style.cursor='grab';}});
  c.addEventListener('wheel',e=>{e.preventDefault();const f=e.deltaY<0?1.15:0.87;cZoom=Math.max(0.15,Math.min(12,cZoom*f));drawChart();},{passive:false});
  c.addEventListener('touchstart',e=>{
    if(e.touches.length===1){isDrag=true;dragX=e.touches[0].clientX;tStartY=e.touches[0].clientY;dragOff=cOff;}
    else if(e.touches.length===2){isDrag=false;const dx=e.touches[0].clientX-e.touches[1].clientX,dy=e.touches[0].clientY-e.touches[1].clientY;pDist=Math.sqrt(dx*dx+dy*dy);pZoom=cZoom;}
    e.preventDefault();
  },{passive:false});
  c.addEventListener('touchmove',e=>{
    if(e.touches.length===1&&isDrag){
      const dx=e.touches[0].clientX-dragX,dy=e.touches[0].clientY-tStartY;
      if(Math.abs(dy)>Math.abs(dx)+10){const f=dy<0?1.03:0.97;cZoom=Math.max(0.15,Math.min(12,cZoom*f));}
      else{const W=c.offsetWidth||350,{data:v}=getVis(),cw=W/Math.max(v.length,1);cOff=Math.max(0,Math.min(dragOff+Math.round(-dx/cw),candles.length-5));}
      drawChart();
    }else if(e.touches.length===2){
      const dx=e.touches[0].clientX-e.touches[1].clientX,dy=e.touches[0].clientY-e.touches[1].clientY;
      cZoom=Math.max(0.15,Math.min(12,pZoom*Math.sqrt(dx*dx+dy*dy)/pDist));drawChart();
    }
    e.preventDefault();
  },{passive:false});
  c.addEventListener('touchend',e=>{
    isDrag=false;
    if(e.changedTouches.length===1){
      const dx=Math.abs(e.changedTouches[0].clientX-dragX),dy=Math.abs(e.changedTouches[0].clientY-tStartY);
      if(dx<5&&dy<5){if(Date.now()-(c._lt||0)<300){cZoom=1;cOff=0;drawChart();toast('↺ Reset','info');}c._lt=Date.now();}
    }
  });
}
