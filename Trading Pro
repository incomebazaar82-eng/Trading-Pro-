setInterval(updPrice,700);
setInterval(renderActive,1000);
setInterval(()=>{const s=sentiment[asset];if(s)updSent();},3000);
window.addEventListener('resize',()=>{drawChart();setupChart();});

// ===== AUTO LOGIN — runs after all functions defined =====
(function autoLogin(){
  try{
    const s=localStorage.getItem('TX_S');
    if(!s) return;
    const a=JSON.parse(s);
    const u=USERS.find(u=>u.e===a.e&&u.p===a.p);
    if(u){ enterApp(u.n,u.e); }
  }catch(e){ localStorage.removeItem('TX_S'); }
})();
</script>

