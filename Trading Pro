  if(isNaN(v)||v<0){toast('Invalid amount','lose');return;}
  const bals=JSON.parse(localStorage.getItem('TX_BAL')||'{}');
  if(!bals[email])bals[email]={b:0,r:0,w:0,t:0};
  bals[email].b=v;localStorage.setItem('TX_BAL',JSON.stringify(bals));
  toast('✅ Balance set to $'+v.toFixed(2),'win');adRenderUsr();
}
function adAddBal(email){
  const uid='u_'+email.replace(/[^a-z0-9]/gi,'_');
  const v=parseFloat(document.getElementById('ba_'+uid).value);
  if(isNaN(v)){toast('Enter amount (use - to deduct)','lose');return;}
  const bals=JSON.parse(localStorage.getItem('TX_BAL')||'{}');
  if(!bals[email])bals[email]={b:0,r:0,w:0,t:0};
  bals[email].b=Math.max(0,(bals[email].b||0)+v);
  localStorage.setItem('TX_BAL',JSON.stringify(bals));
  toast((v>=0?'✅ Added $':'✅ Deducted $')+Math.abs(v).toFixed(2),'win');
  document.getElementById('ba_'+uid).value='';adRenderUsr();
}
function adApprove(id){
  const reqs=JSON.parse(localStorage.getItem('TX_REQUESTS')||'[]');
  const r=reqs.find(x=>x.id===id);
  if(!r||r.status!=='pending')return;
  r.status='approved';r.resolvedAt=new Date().toISOString();
  if(r.type==='deposit'&&r.user){
    const bals=JSON.parse(localStorage.getItem('TX_BAL')||'{}');
    if(!bals[r.user])bals[r.user]={b:0,r:0,w:0,t:0};
    bals[r.user].b=(bals[r.user].b||0)+(r.amount||0);
    localStorage.setItem('TX_BAL',JSON.stringify(bals));
    toast('✅ Deposit approved! $'+adFmtAmt(r.amount)+' credited.','win');
  } else {toast('✅ Withdrawal approved.','win');}
  localStorage.setItem('TX_REQUESTS',JSON.stringify(reqs));
  adCloseModal();adRefresh();
}
function adReject(id){
  const reqs=JSON.parse(localStorage.getItem('TX_REQUESTS')||'[]');
  const r=reqs.find(x=>x.id===id);
  if(!r||r.status!=='pending')return;
  r.status='rejected';r.resolvedAt=new Date().toISOString();
  if(r.type==='withdraw'&&r.user){
    const bals=JSON.parse(localStorage.getItem('TX_BAL')||'{}');
    if(!bals[r.user])bals[r.user]={b:0,r:0,w:0,t:0};
    bals[r.user].b=(bals[r.user].b||0)+(r.amount||0);
    localStorage.setItem('TX_BAL',JSON.stringify(bals));
    toast('❌ Withdrawal rejected. $'+adFmtAmt(r.amount)+' refunded.','info');
  } else {toast('❌ Deposit rejected.','info');}
  localStorage.setItem('TX_REQUESTS',JSON.stringify(reqs));
  adCloseModal();adRefresh();
}
