function doSignup(){
  const nm=document.getElementById('SN').value.trim(),em=document.getElementById('SE').value.trim(),pw=document.getElementById('SP').value,cf=document.getElementById('SC').value;
  if(!nm){toast('Enter your full name','lose');return;}
  if(!em||!/\S+@\S+\.\S+/.test(em)){toast('Invalid email','lose');return;}
